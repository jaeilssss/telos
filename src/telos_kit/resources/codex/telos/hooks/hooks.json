{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/scripts/spec_gate.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\spec_gate.py\"",
            "timeout": 5,
            "statusMessage": "Checking SPEC.md"
          }
        ]
      }
    ]
  }
}
